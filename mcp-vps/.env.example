# Configuração da VPS — preencha e renomeie para .env

# IP ou domínio da VPS
VPS_HOST=SEU_IP_OU_DOMINIO

# Porta SSH (padrão: 22)
VPS_PORT=22

# Usuário SSH
VPS_USER=root

# Autenticação: use KEY ou PASSWORD (prefira key)
VPS_KEY_PATH=C:\Users\Felipe\.ssh\id_rsa
# VPS_PASSWORD=sua_senha_aqui

# Caminho da pasta onde está o docker-compose.yaml na VPS
VPS_COMPOSE_DIR=/root/saas-whatsapp
